# Smart Glasses Pi v4 environment structure.
# Copy values into a local .env only if your process manager loads .env files.
# The Python settings module reads normal environment variables and also loads
# a local .env file from the project root.

SMART_GLASSES_ENVIRONMENT=production
SMART_GLASSES_PROFILE=pi4_balanced
SMART_GLASSES_LANGUAGE=en
SMART_GLASSES_TIMEZONE=Asia/Colombo

SMART_GLASSES_ROOT=/home/pi/smart-glasses-pi-v4
SMART_GLASSES_CONFIG_DIR=/home/pi/smart-glasses-pi-v4/config
SMART_GLASSES_SETTINGS_FILE=/home/pi/smart-glasses-pi-v4/config/runtime.toml
SMART_GLASSES_MODEL_DIR=/home/pi/smart-glasses-pi-v4/models
SMART_GLASSES_STORAGE_DIR=/home/pi/smart-glasses-pi-v4/storage
SMART_GLASSES_FACE_STORE_DIR=/home/pi/smart-glasses-pi-v4/storage/faces
SMART_GLASSES_CACHE_DIR=/home/pi/smart-glasses-pi-v4/storage/cache
SMART_GLASSES_LOG_DIR=/home/pi/smart-glasses-pi-v4/storage/logs
SMART_GLASSES_SETTINGS_DIR=/home/pi/smart-glasses-pi-v4/storage/settings

SMART_GLASSES_CAMERA_WIDTH=1280
SMART_GLASSES_CAMERA_HEIGHT=720
SMART_GLASSES_INFERENCE_WIDTH=640
SMART_GLASSES_INFERENCE_HEIGHT=360
SMART_GLASSES_TARGET_FPS=24
SMART_GLASSES_MAX_FRAME_AGE_MS=160
SMART_GLASSES_CAMERA_HFLIP=false
SMART_GLASSES_CAMERA_VFLIP=false

SMART_GLASSES_TTS_BACKEND=espeak-ng
SMART_GLASSES_TTS_VOICE=en-us
SMART_GLASSES_TTS_RATE_WPM=165
SMART_GLASSES_TTS_VOLUME=0.95
SMART_GLASSES_QUIET_LOWEST_AUDIO_PRIORITY=P1_DANGER

SMART_GLASSES_DIAGNOSTICS_ENABLED=true
SMART_GLASSES_METRICS_INTERVAL_SECONDS=5
